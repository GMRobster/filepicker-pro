  "version": "1.1.0",
  "compatibility": {
    "minimum": "11",
    "verified": "12"
  },
  "authors": [
    {
      "name": "Robster",
      "flags": {}
    }
  ],
  "esmodules": [
    "scripts/main.mjs"
  ],
  "styles": [
    "styles/asset-navigator.css"
  ],
  "languages": [
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de.json"
    },
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "flags": {}
}
